        {
          "name": "09 - Register Second User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token2', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Second User\",\n  \"email\": \"second@test.com\",\n  \"password\": \"12345678\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "10 - Get All Posts Public",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/posts"
          }
        },
        {
          "name": "11 - Get All Posts With Pagination",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/posts?page=0&size=5",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "12 - Create Post Success",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/posts",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Blog Post\",\n  \"content\": \"This is the content of my first blog post on the platform.\"\n}"
            }
          }
        },
